# Django
DJANGO_SETTINGS_MODULE=server.settings
# Required for Airflow tasks that call the Django ORM synchronously from async workers.
DJANGO_ALLOW_ASYNC_UNSAFE=true

# FTP
BASE_FTP_PATH=BaseDatosRadiometro

# Database
POSTGRES_DB=spectrumsaber-db

# Airflow
# Must match the host user UID on Linux so mounted volume files are not owned by root.
# Override in .env with the output of `id -u` if different.
AIRFLOW_UID=1000

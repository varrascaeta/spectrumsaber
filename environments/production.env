# Django
DJANGO_SETTINGS_MODULE=server.settings
DJANGO_ALLOW_ASYNC_UNSAFE=true
# Python
PYTHONPATH=/app/project/src:$PYTHONPATH
# FTP
BASE_FTP_PATH=BaseDatosRadiometro
# DB config
# Set POSTGRES_USER and POSTGRES_PASSWORD in .env
POSTGRES_DB=spectrumsaber-db
POSTGRES_HOST=spectrumsaber-db
POSTGRES_PORT=5432
# Airflow
AIRFLOW_HOME=/app/project/
DAGS_FOLDER=/app/project/src/etl/dags
AIRFLOW_UID=1000
AIRFLOW_WEBSERVER=http://airflow-webserver:8080
# Admin user
DJANGO_ADMIN_USER=admin
DJANGO_ADMIN_PASSWORD=spectrum!2025
# GraphQL
GRAPHQL_ENDPOINT=http://spectrumsaber-app:8000/graphql/
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.
#
# Required vs optional:
#   [required] must be set or the service will fail to start / connect.
#   [optional] has a working default or is only needed for specific features.


# ── FTP ───────────────────────────────────────────────────────────────────────
# [required] CONAE FTP server credentials. Used by Airflow DAGs and the CLI.
FTP_HOST=
FTP_USER=
FTP_PASSWORD=


# ── App database ──────────────────────────────────────────────────────────────
# [required] Credentials for the Django app's PostgreSQL container.
#
# POSTGRES_USER / POSTGRES_PASSWORD are used by the postgres Docker image to
# initialise the superuser on first start. APP_POSTGRES_USER / APP_POSTGRES_PASSWORD
# are used by Django (settings.py) to open the connection — both pairs must match.
APP_POSTGRES_USER=
APP_POSTGRES_PASSWORD=
POSTGRES_USER=          # must equal APP_POSTGRES_USER
POSTGRES_PASSWORD=      # must equal APP_POSTGRES_PASSWORD


# ── Airflow database ──────────────────────────────────────────────────────────
# [required] Credentials for the Airflow-dedicated PostgreSQL container.
AIRFLOW_POSTGRES_USER=
AIRFLOW_POSTGRES_PASSWORD=
AIRFLOW_POSTGRES_DB=


# ── Airflow web UI ────────────────────────────────────────────────────────────
# [optional] Airflow UI login. Defaults to airflow / airflow if not set.
_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=


# ── Airflow UID ───────────────────────────────────────────────────────────────
# [required on Linux] Must match your host user UID so mounted volume files are
# not owned by root. Run `id -u` to get your UID.
AIRFLOW_UID=1000


# ── Django superuser ─────────────────────────────────────────────────────────
# [required] Used by `make setup` / `make createsuperuser` (--noinput).
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=


# ── CLI client ────────────────────────────────────────────────────────────────
# [optional] Pre-fill credentials for non-interactive CLI use (`spectrumsaber --query ...`).
GRAPHQL_USERNAME=
GRAPHQL_PASSWORD=

# [optional] Skip the login step by providing a pre-existing JWT token.
GRAPHQL_JWT_TOKEN=


# ── LLM (text-to-GraphQL) ─────────────────────────────────────────────────────
# [optional] Required only when using `make t2gql` or `spectrumsaber --text2gql`.
# LLM_PROVIDER: openai | anthropic
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o
